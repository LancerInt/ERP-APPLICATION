# ===================================
# Django Configuration
# ===================================
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ENVIRONMENT=production

# ===================================
# Database Configuration
# ===================================
DATABASE_URL=postgresql://erp_user:password@localhost:5432/erp_db
DATABASE_NAME=erp_db
DATABASE_USER=erp_user
DATABASE_PASSWORD=secure-password-here
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ===================================
# Redis Configuration
# ===================================
REDIS_URL=redis://:password@localhost:6379/0
REDIS_PASSWORD=redis-password-here
REDIS_HOST=localhost
REDIS_PORT=6379

# ===================================
# Celery Configuration
# ===================================
CELERY_BROKER_URL=redis://:password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:password@localhost:6379/2
CELERY_RESULT_EXPIRES=3600
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3500

# ===================================
# Django Settings
# ===================================
ALLOWED_HOSTS=localhost,127.0.0.1,example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://example.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://example.com
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ===================================
# AWS S3 Configuration (Production)
# ===================================
USE_S3=True
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=your-bucket-name.s3.amazonaws.com
AWS_S3_URL_PROTOCOL=https
AWS_QUERYSTRING_AUTH=False
AWS_DEFAULT_ACL=public-read

# ===================================
# Email Configuration
# ===================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@lancererp.com
SERVER_EMAIL=server@lancererp.com

# ===================================
# LLM Configuration (for AI Parser)
# ===================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ===================================
# Logging Configuration
# ===================================
LOG_LEVEL=INFO
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===================================
# Application Settings
# ===================================
COMPANY_NAME=Your Company
COMPANY_EMAIL=contact@example.com
COMPANY_PHONE=+1234567890
COMPANY_ADDRESS=123 Main St, City, State 12345

# ===================================
# Security Settings
# ===================================
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_NUMBERS=True
PASSWORD_REQUIRE_SPECIAL=True
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=900

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_API=100/hour
RATE_LIMIT_AUTH=10/hour
RATE_LIMIT_FILE_UPLOAD=5/hour

# ===================================
# Pagination
# ===================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ===================================
# File Upload
# ===================================
MAX_UPLOAD_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,xls,xlsx,csv,doc,docx,jpg,jpeg,png
TEMP_FILE_CLEANUP_DAYS=7

# ===================================
# Features
# ===================================
ENABLE_OCR=True
ENABLE_AI_PARSER=True
ENABLE_ANALYTICS=True
ENABLE_AUDIT_LOG=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_NOTIFICATIONS=False

# ===================================
# OCR Configuration
# ===================================
TESSERACT_PATH=/usr/bin/tesseract
POPPLER_PATH=/usr/bin
OCR_LANGUAGE=eng
OCR_THREADS=4

# ===================================
# Celery Beat Schedule
# ===================================
CELERY_BEAT_SCHEDULE_CHECK_PO_OVERDUE=*/5
CELERY_BEAT_SCHEDULE_AUTO_MATCH_BANK=*/60
CELERY_BEAT_SCHEDULE_COUNTER_REMINDER=*/60
CELERY_BEAT_SCHEDULE_DAILY_REPORTS=6
CELERY_BEAT_SCHEDULE_ATTENDANCE_SUMMARY=18
CELERY_BEAT_SCHEDULE_WEEKLY_RECONCILIATION=monday:6:00
CELERY_BEAT_SCHEDULE_MONTHLY_ADJUSTMENT=1:6:00

# ===================================
# Backup Configuration
# ===================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# ===================================
# Monitoring
# ===================================
ENABLE_METRICS=True
METRICS_PORT=9090
ENABLE_HEALTH_CHECK=True
HEALTH_CHECK_INTERVAL=30

# ===================================
# Cache Configuration
# ===================================
CACHE_TIMEOUT_DEFAULT=300
CACHE_TIMEOUT_MASTER_DATA=3600
CACHE_TIMEOUT_STOCK_BALANCE=300
CACHE_TIMEOUT_SESSION=1800
CACHE_TIMEOUT_OTP=600
