# ===================================
# Root Environment Configuration
# ===================================

# Environment
ENVIRONMENT=development
DEBUG=False

# ===================================
# Database Configuration
# ===================================
DATABASE_NAME=erp_db
DATABASE_USER=erp_user
DATABASE_PASSWORD=secure-password-here

# ===================================
# Redis Configuration
# ===================================
REDIS_PASSWORD=redis-password-here

# ===================================
# Django Secret Key
# ===================================
SECRET_KEY=your-very-long-secret-key-change-this-in-production

# ===================================
# Django Settings
# ===================================
ALLOWED_HOSTS=localhost,127.0.0.1,*.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://example.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://example.com

# ===================================
# AWS Configuration (for S3 storage)
# ===================================
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ===================================
# Email Configuration
# ===================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@lancererp.com

# ===================================
# LLM Configuration
# ===================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=

# ===================================
# Sentry Configuration
# ===================================
SENTRY_DSN=

# ===================================
# Frontend Configuration
# ===================================
FRONTEND_API_URL=http://localhost:8000

# ===================================
# SSL/HTTPS Configuration
# ===================================
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
